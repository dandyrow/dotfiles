**/zsh/plugins
.zcompdump

# Secrets directory — contains hashed passwords, must never be committed.
secrets/

# Ignore all gnupg files apart from the config files
gnupg/.local/share/gnupg/
!gnupg/.local/share/gnupg/gpg-agent.conf
!gnupg/.local/share/gnupg/gpg.conf

# Nix build outputs
result
result-*
*.wsl

# Superpowers design/plan files — local use only, not for version control
docs/superpowers/
